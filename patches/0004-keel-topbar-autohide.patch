diff --git a/chrome/browser/ui/views/frame/browser_view.cc b/chrome/browser/ui/views/frame/browser_view.cc
--- a/chrome/browser/ui/views/frame/browser_view.cc
+++ b/chrome/browser/ui/views/frame/browser_view.cc
@@
 void BrowserView::InitViews() {
   ...
   toolbar_ = AddChildView(std::make_unique<ToolbarView>(browser_.get(), this));
+
+  // keel: install peek strip + autohide controller. The strip is a sibling
+  // of toolbar_ so we can hide one or the other depending on state. The
+  // controller owns the hot-zone view and the visibility state machine.
+  keel_strip_ = std::make_unique<keel::KeelMinimalToolbar>(this);
+  AddChildView(keel_strip_.get());
+  keel_autohide_ = std::make_unique<keel::KeelAutohideController>(
+      this, toolbar_, keel_strip_.get());
 }

@@
 gfx::Size BrowserView::GetMinimumSize() const {
   ...
+  // keel: in the autohide steady state we only need room for the 28px strip.
+  if (keel_autohide_ && keel_autohide_->IsCollapsed()) {
+    return gfx::Size(min.width(),
+                     min.height() - toolbar_->GetPreferredSize().height()
+                                  + keel_strip_->GetPreferredSize().height());
+  }
   return min;
 }

diff --git a/brave/browser/ui/views/keel/keel_autohide_controller.h b/brave/browser/ui/views/keel/keel_autohide_controller.h
new file mode 100644
--- /dev/null
+++ b/brave/browser/ui/views/keel/keel_autohide_controller.h
@@
+// Copyright 2026 Keel. Licensed MIT.
+#ifndef BRAVE_BROWSER_UI_VIEWS_KEEL_KEEL_AUTOHIDE_CONTROLLER_H_
+#define BRAVE_BROWSER_UI_VIEWS_KEEL_KEEL_AUTOHIDE_CONTROLLER_H_
+
+#include "base/timer/timer.h"
+#include "ui/views/view_observer.h"
+#include "ui/events/event_observer.h"
+
+class BrowserView;
+class ToolbarView;
+
+namespace keel {
+
+class KeelMinimalToolbar;
+
+// Drives the two-state top bar: 28-px strip (Collapsed) vs full single-row
+// toolbar (Expanded). Switches state in response to:
+//   - Cursor in the top hot-zone for HotzoneDwellMs (default 80)
+//   - F6 / Ctrl+L / Ctrl+T accelerator
+//   - Extension popup opening (BrowserActionView observer)
+//   - WebContents losing focus (mouse left chrome onto the page)
+//
+// All transitions are 180ms ease-out, instant when ui::PrefersReducedMotion.
+class KeelAutohideController : public views::ViewObserver,
+                               public ui::EventObserver {
+ public:
+  enum class State { kCollapsed, kExpanded };
+
+  KeelAutohideController(BrowserView* browser_view,
+                         ToolbarView* toolbar,
+                         KeelMinimalToolbar* strip);
+  ~KeelAutohideController() override;
+
+  bool IsCollapsed() const { return state_ == State::kCollapsed; }
+
+  void Summon();
+  void DismissAfterDelay();
+  void SetPinned(bool pinned);  // right-click → "Keep chrome visible"
+
+  // ui::EventObserver
+  void OnEvent(const ui::Event& event) override;
+
+ private:
+  void TransitionTo(State new_state);
+  bool ShouldAnimate() const;
+
+  BrowserView* const browser_view_;
+  ToolbarView* const toolbar_;
+  KeelMinimalToolbar* const strip_;
+
+  State state_ = State::kCollapsed;
+  bool pinned_ = false;
+  base::OneShotTimer dismiss_timer_;
+  base::OneShotTimer dwell_timer_;
+};
+
+}  // namespace keel
+#endif  // BRAVE_BROWSER_UI_VIEWS_KEEL_KEEL_AUTOHIDE_CONTROLLER_H_

diff --git a/brave/browser/ui/views/keel/keel_autohide_controller.cc b/brave/browser/ui/views/keel/keel_autohide_controller.cc
new file mode 100644
--- /dev/null
+++ b/brave/browser/ui/views/keel/keel_autohide_controller.cc
@@
+// Copyright 2026 Keel. Licensed MIT.
+#include "brave/browser/ui/views/keel/keel_autohide_controller.h"
+
+#include "base/time/time.h"
+#include "chrome/browser/ui/views/frame/browser_view.h"
+#include "chrome/browser/ui/views/toolbar/toolbar_view.h"
+#include "brave/browser/ui/views/keel/keel_minimal_toolbar.h"
+#include "ui/base/ui_base_features.h"
+#include "ui/events/event.h"
+#include "ui/gfx/animation/tween.h"
+
+namespace keel {
+namespace {
+constexpr base::TimeDelta kSummonAnimation = base::Milliseconds(180);
+constexpr base::TimeDelta kDismissDelay     = base::Milliseconds(1200);
+constexpr base::TimeDelta kHotzoneDwell     = base::Milliseconds(80);
+constexpr int kHotzoneHeightPx = 60;
+}  // namespace
+
+KeelAutohideController::KeelAutohideController(BrowserView* bv,
+                                               ToolbarView* tb,
+                                               KeelMinimalToolbar* st)
+    : browser_view_(bv), toolbar_(tb), strip_(st) {
+  // Listen for mouse events on the BrowserView so we know when the cursor
+  // enters the top hot-zone. Cheap; no input routing changes.
+  browser_view_->AddPreTargetHandler(this);
+
+  // Initial paint in collapsed state.
+  TransitionTo(State::kCollapsed);
+}
+
+KeelAutohideController::~KeelAutohideController() {
+  if (browser_view_) browser_view_->RemovePreTargetHandler(this);
+}
+
+void KeelAutohideController::Summon() {
+  TransitionTo(State::kExpanded);
+}
+
+void KeelAutohideController::DismissAfterDelay() {
+  if (pinned_) return;
+  dismiss_timer_.Start(FROM_HERE, kDismissDelay, this,
+                       &KeelAutohideController::TransitionTo,
+                       State::kCollapsed);
+}
+
+void KeelAutohideController::SetPinned(bool pinned) {
+  pinned_ = pinned;
+  if (pinned) TransitionTo(State::kExpanded);
+}
+
+void KeelAutohideController::OnEvent(const ui::Event& event) {
+  if (!event.IsMouseEvent()) return;
+  const auto& me = static_cast<const ui::MouseEvent&>(event);
+
+  const gfx::Point loc = me.location();
+  const bool in_hotzone = loc.y() < kHotzoneHeightPx;
+
+  if (event.type() == ui::ET_MOUSE_MOVED) {
+    if (in_hotzone && state_ == State::kCollapsed) {
+      dwell_timer_.Start(FROM_HERE, kHotzoneDwell, this,
+                         &KeelAutohideController::Summon);
+    } else if (!in_hotzone && state_ == State::kExpanded) {
+      DismissAfterDelay();
+    }
+  }
+}
+
+bool KeelAutohideController::ShouldAnimate() const {
+  return !ui::PrefersReducedMotion();
+}
+
+void KeelAutohideController::TransitionTo(State new_state) {
+  if (state_ == new_state) return;
+  state_ = new_state;
+
+  const bool expanded = new_state == State::kExpanded;
+  toolbar_->SetVisible(expanded);
+  strip_->SetVisible(!expanded);
+
+  if (ShouldAnimate()) {
+    // Slide the visible view in from -height to 0 (or out the reverse).
+    auto* visible = expanded ? static_cast<views::View*>(toolbar_)
+                             : static_cast<views::View*>(strip_);
+    visible->SetTransform(gfx::Transform::MakeTranslation(
+        0.f, expanded ? -visible->height() : visible->height()));
+    visible->layer()->GetAnimator()->ScheduleAnimation(
+        std::make_unique<ui::LayerAnimationElement::TranslateTo>(
+            gfx::PointF(0, 0), kSummonAnimation, gfx::Tween::EASE_OUT));
+  }
+
+  browser_view_->Layout();
+}
+
+}  // namespace keel

diff --git a/brave/browser/ui/views/keel/keel_minimal_toolbar.h b/brave/browser/ui/views/keel/keel_minimal_toolbar.h
new file mode 100644
