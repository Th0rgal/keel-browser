+++ b/brave/browser/ui/views/keel/keel_minimal_toolbar.h
@@
+// Copyright 2026 Keel. Licensed MIT.
+#ifndef BRAVE_BROWSER_UI_VIEWS_KEEL_KEEL_MINIMAL_TOOLBAR_H_
+#define BRAVE_BROWSER_UI_VIEWS_KEEL_KEEL_MINIMAL_TOOLBAR_H_
+
+#include "ui/views/view.h"
+
+class BrowserView;
+
+namespace keel {
+
+// 28-px peek strip rendered in the autohide steady state. Shows:
+//   [favicon (active tab's accent)]  host · truncated title  [traffic lights]
+//
+// Traffic-light area is drawn by us; on macOS the native window controls
+// remain functional underneath via a transparent overlay. Strip background
+// is rgba(15,18,20,0.55) with a 20px backdrop blur. The bottom edge carries
+// a 1-px accent line + 24px radial glow tinted by the active tab.
+class KeelMinimalToolbar : public views::View {
+ public:
+  explicit KeelMinimalToolbar(BrowserView* browser_view);
+  ~KeelMinimalToolbar() override;
+
+  // Called by KeelTabAccentObserver when the active tab's accent changes.
+  void SetActiveAccent(SkColor accent);
+
+  // views::View
+  gfx::Size CalculatePreferredSize() const override;
+  void Layout() override;
+  void OnPaint(gfx::Canvas* canvas) override;
+
+ private:
+  BrowserView* const browser_view_;
+  SkColor active_accent_ = SkColorSetRGB(0x53, 0xDA, 0xC6);
+
+  views::Label* host_label_ = nullptr;
+  views::Label* title_label_ = nullptr;
+};
+
+}  // namespace keel
+#endif

diff --git a/brave/browser/ui/views/keel/keel_minimal_toolbar.cc b/brave/browser/ui/views/keel/keel_minimal_toolbar.cc
new file mode 100644
--- /dev/null
+++ b/brave/browser/ui/views/keel/keel_minimal_toolbar.cc
@@
+// Copyright 2026 Keel. Licensed MIT.
+#include "brave/browser/ui/views/keel/keel_minimal_toolbar.h"
+
+#include "chrome/browser/ui/views/frame/browser_view.h"
+#include "ui/gfx/canvas.h"
+#include "ui/views/controls/label.h"
+#include "ui/views/layout/box_layout.h"
+
+namespace keel {
+namespace {
+constexpr int kStripHeight = 28;
+constexpr int kPaddingX    = 14;
+}  // namespace
+
+KeelMinimalToolbar::KeelMinimalToolbar(BrowserView* bv) : browser_view_(bv) {
+  SetPaintToLayer();
+  layer()->SetFillsBoundsOpaquely(false);
+  layer()->SetBackgroundBlur(20.f);
+  SetBackground(views::CreateSolidBackground(
+      SkColorSetARGB(0x8C, 0x0F, 0x12, 0x14)));  // ~55% opacity
+
+  SetLayoutManager(std::make_unique<views::BoxLayout>(
+      views::BoxLayout::Orientation::kHorizontal,
+      gfx::Insets::TLBR(0, kPaddingX, 0, kPaddingX),
+      /*between_child_spacing=*/8));
+
+  host_label_ = AddChildView(std::make_unique<views::Label>());
+  host_label_->SetEnabledColor(SkColorSetRGB(0xA8, 0xAD, 0xB2));
+  host_label_->SetFontList(host_label_->font_list().DeriveWithSizeDelta(-1));
+
+  title_label_ = AddChildView(std::make_unique<views::Label>());
+  title_label_->SetEnabledColor(SkColorSetRGB(0x73, 0x7A, 0x80));
+  title_label_->SetElideBehavior(gfx::ELIDE_TAIL);
+}
+
+KeelMinimalToolbar::~KeelMinimalToolbar() = default;
+
+void KeelMinimalToolbar::SetActiveAccent(SkColor accent) {
+  active_accent_ = accent;
+  SchedulePaint();
+}
+
+gfx::Size KeelMinimalToolbar::CalculatePreferredSize() const {
+  return gfx::Size(0, kStripHeight);
+}
+
+void KeelMinimalToolbar::Layout() {
+  views::View::Layout();
+}
+
+void KeelMinimalToolbar::OnPaint(gfx::Canvas* canvas) {
+  views::View::OnPaint(canvas);
+  // 1-px accent line at the bottom + 24-px glow
+  cc::PaintFlags flags;
+  flags.setColor(active_accent_);
+  flags.setStyle(cc::PaintFlags::kStroke_Style);
+  flags.setStrokeWidth(1);
+  canvas->DrawLine(gfx::Point(0, height() - 1),
+                   gfx::Point(width(), height() - 1), flags);
+
+  // Glow as a Skia DropShadow at very low opacity
+  cc::PaintFlags glow;
+  SkColor glow_color = SkColorSetA(active_accent_, 0x20);
+  glow.setMaskFilter(SkMaskFilter::MakeBlur(
+      SkBlurStyle::kNormal_SkBlurStyle, /*sigma=*/12.f));
+  glow.setColor(glow_color);
+  canvas->DrawRect(gfx::Rect(0, height() - 1, width(), 1), glow);
+}
+
+}  // namespace keel

