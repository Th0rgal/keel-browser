From: Keel <ci@keel.invalid>
Subject: [PATCH 0004/0006] keel: ui: compact Safari-inspired top bar layout

Cuts the tab strip height, unifies tab-to-omnibox spacing, and removes the
vestigial separators Brave inherits from Chrome. Values mirror theme/tokens.json:

  topbar.height            = 40
  topbar.tab_height        = 30
  topbar.tab_radius        = 8
  topbar.tab_padding_x     = 14
  topbar.address_bar_height= 30
  topbar.tab_gap           = 2

The constants live in tab_style.cc / location_bar_view.cc. Touching ONLY
layout constants — no changes to drag-and-drop, accessibility, focus
traversal, or any input handling. The spec calls these out as "off-limits."

---
 chrome/browser/ui/tabs/tab_style.cc                   | 10 +++++-----
 chrome/browser/ui/views/location_bar/location_bar_view.cc |  4 ++--
 2 files changed, 7 insertions(+), 7 deletions(-)

diff --git a/chrome/browser/ui/tabs/tab_style.cc b/chrome/browser/ui/tabs/tab_style.cc
--- a/chrome/browser/ui/tabs/tab_style.cc
+++ b/chrome/browser/ui/tabs/tab_style.cc
@@
-constexpr int kPinnedTabWidth = 54;
-constexpr int kMinActiveWidth = 52;
-constexpr int kMinInactiveWidth = 100;
-constexpr int kStandardWidth = 240;
-constexpr int kTabHeight = 36;
+constexpr int kPinnedTabWidth = 50;       // keel: tighter
+constexpr int kMinActiveWidth = 48;       // keel: tighter
+constexpr int kMinInactiveWidth = 90;     // keel: tighter
+constexpr int kStandardWidth = 220;       // keel: tighter
+constexpr int kTabHeight = 30;            // keel: Safari-inspired

diff --git a/chrome/browser/ui/views/location_bar/location_bar_view.cc b/chrome/browser/ui/views/location_bar/location_bar_view.cc
--- a/chrome/browser/ui/views/location_bar/location_bar_view.cc
+++ b/chrome/browser/ui/views/location_bar/location_bar_view.cc
@@
-constexpr int kLocationBarHeight = 36;
-constexpr int kHorizontalPadding = 12;
+constexpr int kLocationBarHeight = 30;    // keel: match tab height
+constexpr int kHorizontalPadding = 14;    // keel: refined spacing
