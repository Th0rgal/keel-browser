{
  "_comment": "Keel design tokens. Mirror the palette defined in KEEL_BROWSER_SPEC.md and feed CSS variables for the new tab page, the build-time Brave theme overrides, and any auxiliary surfaces.",

  "dark": {
    "background":       "#0B0D0E",
    "elevated_surface": "#111416",
    "toolbar":          "#0F1214",
    "address_bar":      "#181C1F",
    "border":           "#252A2E",
    "border_subtle":    "#1B1F23",
    "text_primary":     "#F2F2EF",
    "text_secondary":   "#A8ADB2",
    "text_muted":       "#737A80",
    "accent":           "#53DAC6",
    "accent_dim":       "#3FB0A0",
    "tab_active_bg":    "#1A1E22",
    "tab_inactive_bg":  "#0F1214",
    "tab_hover_bg":     "#15191D"
  },

  "light": {
    "background":       "#F7F6F2",
    "elevated_surface": "#FFFFFF",
    "toolbar":          "#F0EFEA",
    "address_bar":      "#FFFFFF",
    "border":           "#D9D7D0",
    "border_subtle":    "#E8E6DF",
    "text_primary":     "#161616",
    "text_secondary":   "#555A60",
    "text_muted":       "#8A8E92",
    "accent":           "#53DAC6",
    "accent_dim":       "#2F9D8C",
    "tab_active_bg":    "#FFFFFF",
    "tab_inactive_bg":  "#F0EFEA",
    "tab_hover_bg":     "#E8E6DF"
  },

  "topbar": {
    "_comment": "Two-state top bar: a 28px strip in the steady state, a 38px single combined row when summoned. See docs/design/navbar-ideas.md and patches/0004-keel-topbar-autohide.patch.",
    "strip_height": 28,
    "bar_height": 38,
    "tab_height": 26,
    "tab_radius": 6,
    "tab_padding_x": 10,
    "tab_marker_width": 2,
    "tab_max_width": 160,
    "tab_gap": 4,
    "address_bar_radius": 8,
    "address_bar_height": 28,
    "address_bar_min_width": 220,
    "toolbar_padding_x": 14,
    "icon_size": 14,
    "icon_button_size": 26,
    "hotzone_height": 60,
    "hotzone_dwell_ms": 80,
    "summon_animation_ms": 180,
    "dismiss_delay_ms": 1200,
    "blur_radius_px": 20,
    "strip_opacity": 0.55,
    "bar_opacity": 0.78,
    "saturate_pct": 160
  },

  "tab_tint": {
    "_comment": "Per-tab accent color extracted from the page. Sources in priority order: <meta name=theme-color>, dominant favicon color (LRU per origin), then the static Keel accent. Saturation/lightness clamped so even loud sites stay calm in chrome.",
    "extraction_order": ["meta_theme_color", "favicon_dominant", "static_accent"],
    "hsl_saturation_max": 0.55,
    "hsl_lightness_min": 0.40,
    "hsl_lightness_max": 0.70,
    "url_bar_underline_opacity": 0.60,
    "tab_marker_opacity": 1.00,
    "strip_glow_opacity": 1.00,
    "inactive_tab_dim_pct": 40,
    "favicon_lru_capacity": 256,
    "calmed_examples": {
      "_comment": "Brand colors at the original saturation vs Keel's clamp. Used in mockup.",
      "verity_brand":   "#1FBFA5",
      "verity_keel":    "#53DAC6",
      "hn_brand":       "#FF6600",
      "hn_keel":        "#C97A4A",
      "arxiv_brand":    "#B31B1B",
      "arxiv_keel":     "#C0606A",
      "github_brand":   "#3FB950",
      "github_keel":    "#6BA56B"
    }
  },

  "typography": {
    "ui_font_stack": "-apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Inter', 'Segoe UI', system-ui, sans-serif",
    "mono_font_stack": "'SF Mono', 'JetBrains Mono', 'Menlo', 'Consolas', monospace",
    "ui_size": 13,
    "ui_weight": 400,
    "ui_weight_strong": 500
  }
}
